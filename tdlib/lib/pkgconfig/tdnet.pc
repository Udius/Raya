prefix=/home/udius/Raya/tdlib

Name: tdnet
Description: Telegram Library - Net
Version: 1.8.65

CFlags: -I"${prefix}/include"
Libs: -L"${prefix}/lib" -ltdnet
Requires.private: tdutils tdactor
Libs.private: -L"/usr/lib/x86_64-linux-gnu" -lssl -L"/usr/lib/x86_64-linux-gnu" -lcrypto -ldl -L"/usr/lib/x86_64-linux-gnu" -lz
